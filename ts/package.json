{
  "name": "@whatsmeow-node/whatsmeow-node",
  "version": "0.5.0",
  "whatsmeowVersion": "0.0.0-20260305",
  "description": "TypeScript bindings for whatsmeow (Go WhatsApp library) via subprocess IPC",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run --exclude 'src/__tests__/e2e.test.ts' --exclude 'src/__tests__/integration/**'",
    "test:e2e": "vitest run --config vitest.config.e2e.ts",
    "test:integration": "vitest run -c vitest.config.integration.ts",
    "test:integration:coverage": "COVERAGE=1 vitest run -c vitest.config.integration.ts",
    "test:watch": "vitest --exclude 'src/__tests__/e2e.test.ts' --exclude 'src/__tests__/integration/**'",
    "format": "prettier --write 'src/**/*.ts'",
    "check:examples": "tsc --noEmit -p tsconfig.examples.json",
    "format:check": "prettier --check 'src/**/*.ts'"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nicastelo/whatsmeow-node.git",
    "directory": "ts"
  },
  "homepage": "https://github.com/nicastelo/whatsmeow-node#readme",
  "bugs": {
    "url": "https://github.com/nicastelo/whatsmeow-node/issues"
  },
  "author": "Nicolas Castellanos (https://github.com/nicastelo)",
  "keywords": [
    "whatsapp",
    "whatsmeow",
    "whatsapp-api",
    "whatsapp-web",
    "whatsapp-bot",
    "go",
    "ipc"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "optionalDependencies": {
    "@whatsmeow-node/darwin-arm64": "0.5.0",
    "@whatsmeow-node/darwin-x64": "0.5.0",
    "@whatsmeow-node/linux-arm64": "0.5.0",
    "@whatsmeow-node/linux-x64": "0.5.0",
    "@whatsmeow-node/linux-x64-musl": "0.5.0",
    "@whatsmeow-node/win32-arm64": "0.5.0",
    "@whatsmeow-node/win32-x64": "0.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "qrcode-terminal": "^0.12.0",
    "tsup": "^8.5.1",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  }
}
